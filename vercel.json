{
  "version": 2,
  "name": "tubbys-tumblerz",
  "routes": [
    { "src": "/etsy", "dest": "/api/etsy.js" }
  ],
  "build": {
    "env": { "NODE_VERSION": "18" }
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "headers": [
    {
      "source": "(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
